{
  "name": "@sitespeed.io/log",
  "description": "The log for sitespeed.io projects",
  "version": "1.0.0",
  "type": "module",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "ava": "8.0.0",
    "eslint": "10.4.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-unicorn": "64.0.0",
    "globals": "17.6.0",
    "prettier": "3.8.3"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "src/*"
  ],
  "exports": {
    ".": {
      "import": "./src/index.js"
    }
  },
  "scripts": {
    "test": "ava",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "author": "Peter Hedenskog",
  "repository": {
    "type": "git",
    "url": "https://github.com/sitespeedio/log.git"
  },
  "license": "Apache-2.0",
  "ava": {
    "files": [
      "test/**/*"
    ],
    "concurrency": 1,
    "failFast": false,
    "nodeArguments": [
      "--trace-deprecation"
    ]
  }
}
